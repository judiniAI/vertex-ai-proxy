  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build:cloudrun": "tsc -p tsconfig.cloudrun.json",
    "start": "node dist/server.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  }
}

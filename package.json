{
  "name": "vertex-ai-gateway",
  "version": "1.0.0",
  "description": "Open-source Cloudflare Worker: OpenAI-compatible proxy for Google Vertex AI. Use as Custom LLM endpoint for ElevenLabs or any OpenAI client.",
